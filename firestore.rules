rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function householdDoc(householdId) {
      return get(/databases/$(database)/documents/households/$(householdId));
    }

    function isHouseholdMember(householdId) {
      return signedIn()
        && householdDoc(householdId).data.memberIDs is list
        && request.auth.uid in householdDoc(householdId).data.memberIDs;
    }

    match /users/{userId} {
      allow read, delete: if isSelf(userId);
      allow create: if isSelf(userId);
      allow update: if isSelf(userId);
    }

    match /households/{householdId} {
      allow read: if isHouseholdMember(householdId);

      allow create: if signedIn()
        && request.resource.data.createdByUserID == request.auth.uid
        && request.resource.data.memberIDs is list
        && request.auth.uid in request.resource.data.memberIDs;

      allow update, delete: if isHouseholdMember(householdId);

      match /tags/{tagId} {
        allow read, write: if isHouseholdMember(householdId);
      }

      match /recipes/{recipeId} {
        allow read, write: if isHouseholdMember(householdId);

        match /comments/{commentId} {
          allow read, write: if isHouseholdMember(householdId);
        }

        match /reviews/{reviewUserId} {
          allow read: if isHouseholdMember(householdId);
          allow create, update, delete: if isHouseholdMember(householdId) && reviewUserId == request.auth.uid;
        }
      }
    }
  }
}
